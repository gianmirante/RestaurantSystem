<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex flex-column align-items-center pt-3 text-center">
        <!-- Brand Title Header -->
        <div class="mb-2">
            <img src="images/logo.png" alt="Logo" style="max-width: 120px; height: auto;" onerror="this.style.display='none';" />
            <h5 class="text-dark font-weight-bold m-0 mt-1" style="font-size: 1.1rem; letter-spacing: 0.5px;">Restaurant.Client</h5>
        </div>
        <!-- User Avatar Circle Graphic Icon -->
        <div class="my-2">
            <span class="oi oi-person text-dark" style="font-size: 2.2rem; display: inline-block;" aria-hidden="true"></span>
        </div>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable d-flex flex-column justify-content-between" style="height: calc(100vh - 160px);" @onclick="ToggleNavMenu">
    <nav class="nav flex-column w-100">
        <!-- Dashboard -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="home" Match="NavLinkMatch.All">
                <span class="oi oi-dashboard" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <!-- Products -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="products">
                <span class="oi oi-box" aria-hidden="true"></span> Products
            </NavLink>
        </div>

        <!-- Inventory -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="inventory">
                <span class="oi oi-list" aria-hidden="true"></span> Inventory
            </NavLink>
        </div>

        <!-- Orders -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="orders">
                <span class="oi oi-clipboard" aria-hidden="true"></span> Orders
            </NavLink>
        </div>

        <!-- Payments -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="payments">
                <span class="oi oi-credit-card" aria-hidden="true"></span> Payments
            </NavLink>
        </div>

        <!-- Notification -->
        <div class="nav-item px-3">
            <NavLink class="nav-link text-dark font-weight-bold" href="notifications">
                <span class="oi oi-bell" aria-hidden="true"></span> Notification
            </NavLink>
        </div>
    </nav>

    <!-- Logout Pinned To Bottom Block -->
    <div class="nav-item px-3 mb-4 text-center">
        <button class="btn btn-link nav-link w-100 text-center justify-content-center border-0 font-weight-bold text-dark" @onclick="OnLogoutRequest" style="text-decoration: none;">
            Logout
        </button>
    </div>
</div>

@code {
    [Parameter] public string? NavMenuCssClass { get; set; }
    [Parameter] public EventCallback ToggleNavMenu { get; set; }
    [Parameter] public EventCallback OnLogoutRequest { get; set; }
}