@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<!-- 🍳 FULL WIDTH KITCHEN STAFF DASHBOARD COMPONENT -->
<div class="container-fluid p-4" style="background-color: #E0E0E0; min-height: 100vh; width: 100vw;">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center p-3 rounded shadow-sm" style="background-color: #D2D2D2;">
            <h3 class="m-0 font-weight-bold text-dark">🍳 Kitchen Display System (KDS)</h3>
            
            <!-- 🟢 Actions layout side-by-side -->
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-danger p-2 px-3 m-0" style="font-size: 0.9rem; border-radius: 4px;">Active Pipeline</span>
                
                <button class="btn btn-outline-dark font-weight-bold border-dark px-3 py-1 bg-white text-dark shadow-sm" 
                        @onclick="HandleLogout" 
                        style="border-radius: 4px; font-size: 0.9rem; border: 1px solid #212529;">
                    <span class="oi oi-account-logout me-1" aria-hidden="true"></span> Logout
                </button>
            </div>
        </div>
    </div>

    <!-- Active Tickets Layout Grid remains perfectly styled here -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="background-color: #D2D2D2; border-radius: 4px;">
                <div class="card-header border-0 d-flex justify-content-between align-items-center bg-dark text-white p-3">
                    <span class="font-weight-bold">Order #204</span>
                    <span class="badge bg-warning text-dark">10 mins ago</span>
                </div>
                <div class="card-body p-3">
                    <ul class="list-group list-group-flush bg-transparent">
                        <li class="list-group-item bg-transparent px-0 font-weight-bold text-danger">2x Ribeye Steak (Medium)</li>
                        <li class="list-group-item bg-transparent px-0">1x Crispy Pata</li>
                        <li class="list-group-item bg-transparent px-0">3x Garlic Rice</li>
                    </ul>
                    <button class="btn btn-success w-100 mt-3 font-weight-bold border-0 shadow-sm">Mark Complete ✓</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="background-color: #D2D2D2; border-radius: 4px;">
                <div class="card-header border-0 d-flex justify-content-between align-items-center bg-dark text-white p-3">
                    <span class="font-weight-bold">Order #205</span>
                    <span class="badge bg-warning text-dark">3 mins ago</span>
                </div>
                <div class="card-body p-3">
                    <ul class="list-group list-group-flush bg-transparent">
                        <li class="list-group-item bg-transparent px-0 font-weight-bold">1x Pork Afritada</li>
                        <li class="list-group-item bg-transparent px-0">2x Canton Noodles</li>
                    </ul>
                    <button class="btn btn-success w-100 mt-3 font-weight-bold border-0 shadow-sm">Mark Complete ✓</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await AuthStateProvider.GetAuthenticationStateAsync();
        Navigation.NavigateTo("/");
    }
}