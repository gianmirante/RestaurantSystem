@page "/orders"
@attribute [Authorize(Roles = "Admin")]

<div class="container-fluid p-4" style="background-color: #E0E0E0; min-height: 100vh;">
    
    <!-- Header Title Stack -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h3 class="font-weight-bold text-dark m-0">Orders</h3>
            <h5 class="text-secondary font-weight-bold m-0" style="font-size: 1.1rem;">Table</h5>
        </div>
        
        <!-- 🟢 Top-Right Counter Filter Pills (Matching image_8e8940.png) -->
        <div class="d-flex gap-2">
            <button class="btn btn-info text-white font-weight-bold btn-sm p-2 d-flex align-items-center gap-2 @(currentFilter == "Order" ? "border-dark shadow" : "border-0")" 
                    @onclick='() => SetFilter("Order")' style="background-color: #00B4D8; border-radius: 4px; font-size: 0.85rem;">
                Order <span class="badge bg-dark text-white font-weight-bold">@orders.Count(o => o.Status == "Order")</span>
            </button>
            <button class="btn btn-info text-white font-weight-bold btn-sm p-2 d-flex align-items-center gap-2 @(currentFilter == "Confirm" ? "border-dark shadow" : "border-0")" 
                    @onclick='() => SetFilter("Confirm")' style="background-color: #00B4D8; border-radius: 4px; font-size: 0.85rem;">
                Confirm <span class="badge bg-dark text-white font-weight-bold">@orders.Count(o => o.Status == "Confirm")</span>
            </button>
            <button class="btn btn-info text-white font-weight-bold btn-sm p-2 d-flex align-items-center gap-2 @(currentFilter == "Pick-up" ? "border-dark shadow" : "border-0")" 
                    @onclick='() => SetFilter("Pick-up")' style="background-color: #00B4D8; border-radius: 4px; font-size: 0.85rem;">
                Pick up <span class="badge bg-dark text-white font-weight-bold">@orders.Count(o => o.Status == "Pick-up")</span>
            </button>
            @if (currentFilter != "All")
            {
                <button class="btn btn-sm btn-dark font-weight-bold" @onclick='() => SetFilter("All")' style="border-radius: 4px;">Clear Filter</button>
            }
        </div>
    </div>

    <!-- 🟢 Main Grid Container Box (#D2D2D2 Layout Theme) -->
    <div class="card border-0 p-4 shadow-sm" style="background-color: #D2D2D2; border-radius: 4px;">
        <div class="table-responsive">
            <table class="table align-middle m-0" style="border-collapse: collapse;">
                <thead>
                    <tr class="border-bottom border-secondary text-dark pb-3">
                        <th class="p-3 font-weight-bold">orderID</th>
                        <th class="p-3 font-weight-bold">Customer</th>
                        <th class="p-3 font-weight-bold">Products</th>
                        <th class="p-3 font-weight-bold text-center">Quantity</th>
                        <th class="p-3 font-weight-bold text-center">Half</th>
                        <th class="p-3 font-weight-bold text-center">Full</th>
                        <th class="p-3 font-weight-bold">Orderdate</th>
                        <th class="p-3 font-weight-bold text-center">Status Update</th>
                        <th class="p-3 font-weight-bold text-center">Paid</th>
                        <th class="p-3 font-weight-bold text-center">Delivery</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in GetFilteredOrders())
                    {
                        <tr class="border-bottom border-secondary pb-3">
                            <!-- Order ID -->
                            <td class="p-3 font-weight-bold text-dark">#@order.Id</td>
                            
                            <!-- Customer Name -->
                            <td class="p-3 font-weight-bold text-dark">@order.CustomerName</td>
                            
                            <!-- Product Stack with Image and Category Tag -->
                            <td class="p-3">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@order.ProductImageUrl" alt="@order.ProductName" class="rounded object-fit-cover shadow-sm" 
                                         style="width: 65px; height: 65px; border-radius: 4px; min-width: 65px;" 
                                         onerror="this.src='https://via.placeholder.com/65'" />
                                    <div>
                                        <small class="text-primary d-block font-weight-bold mb-1" style="font-size: 0.8rem;">@order.ProductCategory</small>
                                        <h6 class="m-0 font-weight-bold text-dark" style="font-size: 1.05rem;">@order.ProductName</h6>
                                    </div>
                                </div>
                            </td>
                            
                            <!-- Quantity -->
                            <td class="p-3 font-weight-bold text-dark text-center">@order.Quantity pcs</td>
                            
                            <!-- Portion Options (Half vs Full Checkboxes) -->
                            <td class="p-3 text-center">
                                <input type="checkbox" checked="@order.IsHalfOption" disabled class="form-check-input border-dark shadow-sm" style="transform: scale(1.1);" />
                            </td>
                            <td class="p-3 text-center">
                                <input type="checkbox" checked="@(!order.IsHalfOption)" disabled class="form-check-input border-dark shadow-sm" style="transform: scale(1.1);" />
                            </td>
                            
                            <!-- Stamp Order Date -->
                            <td class="p-3 font-weight-bold text-dark">@order.OrderDate.ToString("yyyy-MM-dd")</td>
                            
                            <!-- Status Action Text Trigger -->
                            <td class="p-3 text-center">
                                @if (order.Status == "Order")
                                {
                                    <button class="btn btn-sm btn-light border-dark font-weight-bold shadow-sm px-3" @onclick="() => AdvanceStatus(order)" style="border-radius: 4px;">Confirm</button>
                                }
                                else if (order.Status == "Confirm")
                                {
                                    <button class="btn btn-sm btn-dark text-white font-weight-bold shadow-sm px-3" @onclick="() => AdvanceStatus(order)" style="border-radius: 4px;">Ready to Pick up</button>
                                }
                                else
                                {
                                    <span class="text-success font-weight-bold small"><span class="oi oi-check"></span> Processing Pick-up</span>
                                }
                            </td>
                            
                            <!-- Paid Checkbox status -->
                            <td class="p-3 text-center">
                                <input type="checkbox" @bind="order.IsPaid" class="form-check-input border-dark shadow-sm" style="cursor: pointer; transform: scale(1.1);" />
                            </td>
                            
                            <!-- Delivery Target state -->
                            <td class="p-3 text-center font-weight-bold text-dark">
                                @order.Status
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private string currentFilter = "All";

    private void SetFilter(string filter) => currentFilter = filter;

    private IEnumerable<OrderItem> GetFilteredOrders()
    {
        if (currentFilter == "All") return orders;
        return orders.Where(o => o.Status.Equals(currentFilter, StringComparison.OrdinalIgnoreCase));
    }

    private void AdvanceStatus(OrderItem order)
    {
        if (order.Status == "Order") order.Status = "Confirm";
        else if (order.Status == "Confirm") order.Status = "Pick-up";
    }

    // 🟢 Initialized mock dataset precisely matching Basser bantas' Afritada item layout from image_8e8940.png
    private List<OrderItem> orders = new()
    {
        new OrderItem 
        { 
            Id = 1, 
            CustomerName = "Basser bantas", 
            ProductName = "Afritada", 
            ProductCategory = "Pork", 
            Quantity = 2, 
            IsHalfOption = true, 
            OrderDate = new DateTime(2026, 1, 23), 
            Status = "Order", 
            IsPaid = true 
        },
        new OrderItem 
        { 
            Id = 2, 
            CustomerName = "Jane Doe", 
            ProductName = "Bihon", 
            ProductCategory = "Noodles", 
            Quantity = 1, 
            IsHalfOption = false, 
            OrderDate = new DateTime(2026, 6, 22), 
            Status = "Confirm", 
            IsPaid = false 
        },
        new OrderItem 
        { 
            Id = 3, 
            CustomerName = "John Smith", 
            ProductName = "Canton", 
            ProductCategory = "Noodles", 
            Quantity = 4, 
            IsHalfOption = true, 
            OrderDate = new DateTime(2026, 6, 23), 
            Status = "Pick-up", 
            IsPaid = true 
        }
    };

    public class OrderItem
    {
        public int Id { get; set; }
        public string CustomerName { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string ProductCategory { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public bool IsHalfOption { get; set; }
        public DateTime OrderDate { get; set; }
        public string Status { get; set; } = "Order"; // Order -> Confirm -> Pick-up
        public bool IsPaid { get; set; }
        public string ProductImageUrl { get; set; } = "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=150";
    }
}